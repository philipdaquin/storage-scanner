# Copy this to `release.env` for local use.

# Apple signing
DEVELOPER_ID_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# Notarization
# Use either a keychain profile...
NOTARYTOOL_PROFILE="StorageScanner Notary"
# ...or an App Store Connect API key.
# NOTARYTOOL_API_KEY_FILE="/path/to/AuthKey_XXXX.p8"
# NOTARYTOOL_API_KEY_ID="XXXX"
# NOTARYTOOL_API_ISSUER_ID="YYYYYYYY-YYYY-YYYY-YYYY-YYYYYYYYYYYY"

# Sparkle appcast signing
SPARKLE_PRIVATE_KEY_FILE="/path/to/private-ed25519.key"
# SPARKLE_PRIVATE_KEY="base64-or-raw-secret"
SPARKLE_PUBLIC_ED_KEY="base64-public-key"

# Stable feed URL used by the app at runtime.
APPCAST_URL="https://raw.githubusercontent.com/philipdaquin/storage-scanner/main/appcast.xml"

# Optional overrides
# RELEASE_ARCHS="arm64 x86_64"
